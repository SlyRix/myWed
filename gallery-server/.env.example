# Gallery access code — embed in QR URL: ?gallery=THIS_CODE
GALLERY_CODE=RUSHIVANI2025

# Admin token for moderation panel (generate something strong)
ADMIN_TOKEN=change-me-to-something-secret

# Where to store uploaded files (absolute path on home server)
STORAGE_PATH=/gallery-storage

# Public base URL of THIS server (API + file serving) — used to build photo URLs in API responses
# This is the CF Tunnel domain pointing to port 4000 on the home server
BASE_URL=https://gallery-api.rushelwedsivani.com

# Server port
PORT=4000

# OpenAI API key for AI auto-tagging (leave empty to disable tagging)
OPENAI_API_KEY=

# Allowed frontend origins — the CF Pages PWA that makes requests to this API
ALLOWED_ORIGINS=https://gallery.rushelwedsivani.com,https://rushelwedsivani.com,https://wed.rushel.me
